<template>
  <div class="timeline-view">
    <div class="timeline-layout">
      <!-- 左侧垂直时间轴 -->
      <div class="timeline-sidebar">
        <div class="timeline-header">
          <h3>时间轴</h3>
          <n-button
            v-if="currentViewLevel > 'year'"
            text
            size="small"
            @click="handleBackToParent"
          >
            <template #icon>
              <n-icon><ChevronBackOutline /></n-icon>
            </template>
            返回上一级
          </n-button>
        </div>

        <div class="timeline-container" ref="timelineTreeRef">
          <div class="timeline-line"></div>

          <div class="timeline-items">
            <!-- 年级别 -->
            <template v-if="currentViewLevel === 'year'">
              <div
                v-for="yearData in timelineData?.years || []"
                :key="yearData.year"
                class="timeline-item"
                :class="{ 'timeline-item--active': isActiveYear(yearData.year) }"
                @click="handleYearClick(yearData)"
              >
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                  <div class="timeline-title">{{ yearData.year }}年</div>
                  <div class="timeline-desc">{{ yearData.count }}个仓库</div>
                </div>
              </div>
            </template>

            <!-- 月级别 -->
            <template v-else-if="currentViewLevel === 'month'">
              <div
                class="timeline-item timeline-item--parent"
                @click="handleBackToYear"
              >
                <div class="timeline-dot timeline-dot--parent"></div>
                <div class="timeline-content">
                  <div class="timeline-title">{{ selectedYear }}年</div>
                  <div class="timeline-desc">{{ getYearTotal(selectedYear) }}个仓库</div>
                </div>
              </div>

              <div
                v-for="monthData in getCurrentYearMonths()"
                :key="monthData.month"
                class="timeline-item"
                :class="{ 'timeline-item--active': isActiveMonth(monthData.month) }"
                @click="handleMonthClick(monthData)"
              >
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                  <div class="timeline-title">{{ monthData.month }}月</div>
                  <div class="timeline-desc">{{ monthData.count }}个仓库</div>
                </div>
              </div>
            </template>

            <!-- 日级别 -->
            <template v-else-if="currentViewLevel === 'day'">
              <div
                class="timeline-item timeline-item--parent"
                @click="handleBackToMonth"
              >
                <div class="timeline-dot timeline-dot--parent"></div>
                <div class="timeline-content">
                  <div class="timeline-title">{{ selectedYear }}-{{ selectedMonth }}月</div>
                  <div class="timeline-desc">{{ getMonthTotal(selectedYear, selectedMonth) }}个仓库</div>
                </div>
              </div>

              <div
                v-for="dayData in getCurrentMonthDays()"
                :key="dayData.day"
                class="timeline-item"
                :class="{ 'timeline-item--active': isActiveDay(dayData.day) }"
                @click="handleDayClick(dayData)"
              >
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                  <div class="timeline-title">{{ dayData.day }}日</div>
                  <div class="timeline-desc">{{ dayData.count }}个仓库</div>
                </div>
              </div>
            </template>
          </div>
        </div>
      </div>

      <!-- 右侧仓库列表 -->
      <div class="timeline-content">
        <!-- 当前时间段提示 -->
        <n-alert v-if="currentPeriodLabel" type="info" :bordered="false" style="margin-bottom: 16px;">
          <template #icon>
            <n-icon><InformationCircleOutline /></n-icon>
          </template>
          当前查看: <strong>{{ currentPeriodLabel }}</strong>
          (共 {{ reposStore.dimensionRepos.length }} 个仓库)
        </n-alert>

        <!-- 仓库列表 - 支持滚动加载 -->
        <div class="repos-container" ref="reposContainerRef">
          <n-spin :show="reposStore.dimensionLoading">
            <div v-if="reposStore.dimensionRepos.length > 0" class="repos-grid">
              <RepoCard
                v-for="repo in reposStore.dimensionRepos"
                :key="repo.id"
                :repo="repo"
                :repo-status="reposStore.repoStatuses[repo.id]"
                @click="$emit('repo-click', repo)"
                @view-code="$emit('view-code', repo)"
                @open-folder="$emit('open-folder', repo)"
                @clone="$emit('clone', repo)"
                @pull="$emit('pull', repo)"
                @reset="$emit('reset', repo)"
                @delete="$emit('delete', repo)"
                @update-info="$emit('update-info', repo)"
              />
            </div>

            <!-- 加载中提示 -->
            <div v-if="isLoadingMore" class="loading-more">
              <n-spin size="medium" />
              <span>加载中...</span>
            </div>

            <!-- 空状态 -->
            <n-empty
              v-if="!reposStore.dimensionLoading && reposStore.dimensionRepos.length === 0"
              description="该时间段暂无仓库数据"
              size="large"
            />
          </n-spin>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, onUnmounted, nextTick } from 'vue'
import { useMessage } from 'naive-ui'
import {
  ChevronBackOutline,
  ChevronForwardOutline,
  InformationCircleOutline,
  CalendarOutline
} from '@vicons/ionicons5'
import RepoCard from '@/components/repo/RepoCard.vue'
import { useReposStore } from '@/stores/repos'

const message = useMessage()
const reposStore = useReposStore()

// Props
const props = defineProps({
  repos: {
    type: Array,
    default: () => []
  },
  repoStatuses: {
    type: Object,
    default: () => ({})
  },
  loading: {
    type: Boolean,
    default: false
  }
})

// Emits
const emit = defineEmits([
  'repo-click',
  'view-code',
  'open-folder',
  'clone',
  'pull',
  'reset',
  'delete',
  'update-info'
])

// Refs
const timelineTreeRef = ref(null)
const reposContainerRef = ref(null)

// 视图状态
const currentViewLevel = ref('year') // 'year' | 'month' | 'day'
const selectedYear = ref(null)
const selectedMonth = ref(null)
const selectedDay = ref(null)

// 加载状态
const isLoadingMore = ref(false)
const currentPageInPeriod = ref(1)
const hasMore = ref(true)

// 计算属性
const timelineData = computed(() => {
  return reposStore.timelineDimensions
})

const currentPeriodLabel = computed(() => {
  if (currentViewLevel.value === 'year' && selectedYear.value) {
    return `${selectedYear.value}年`
  } else if (currentViewLevel.value === 'month' && selectedYear.value && selectedMonth.value) {
    return `${selectedYear.value}年${selectedMonth.value}月`
  } else if (currentViewLevel.value === 'day' && selectedYear.value && selectedMonth.value && selectedDay.value) {
    return `${selectedYear.value}年${selectedMonth.value}月${selectedDay.value}日`
  }
  return null
})

// 辅助方法
const getCurrentYearMonths = () => {
  if (!timelineData.value?.years) return []
  const yearData = timelineData.value.years.find(y => y.year === selectedYear.value)
  return yearData?.months || []
}

const getCurrentMonthDays = () => {
  const months = getCurrentYearMonths()
  const monthData = months.find(m => m.month === selectedMonth.value)
  return monthData?.days || []
}

const getYearTotal = (year) => {
  const yearData = timelineData.value?.years?.find(y => y.year === year)
  return yearData?.count || 0
}

const getMonthTotal = (year, month) => {
  const months = getCurrentYearMonths()
  const monthData = months.find(m => m.month === month)
  return monthData?.count || 0
}

const isActiveYear = (year) => {
  return currentViewLevel.value === 'month' && selectedYear.value === year
}

const isActiveMonth = (month) => {
  return currentViewLevel.value === 'day' && selectedMonth.value === month
}

const isActiveDay = (day) => {
  return selectedDay.value === day
}

// 时间轴点击处理
const handleYearClick = async (yearData) => {
  selectedYear.value = yearData.year
  selectedMonth.value = null
  selectedDay.value = null
  currentViewLevel.value = 'month'

  // 加载该年份的第一个月数据
  const months = yearData.months || []
  if (months.length > 0) {
    await loadPeriodData({ year: yearData.year, month: months[0].month })
  }
}

const handleMonthClick = async (monthData) => {
  selectedMonth.value = monthData.month
  selectedDay.value = null
  currentViewLevel.value = 'day'

  // 加载该月份的第一天数据
  const days = monthData.days || []
  if (days.length > 0) {
    await loadPeriodData({
      year: selectedYear.value,
      month: monthData.month,
      day: days[0].day
    })
  }
}

const handleDayClick = async (dayData) => {
  selectedDay.value = dayData.day
  await loadPeriodData({
    year: selectedYear.value,
    month: selectedMonth.value,
    day: dayData.day
  })
}

// 返回上一级
const handleBackToParent = () => {
  if (currentViewLevel.value === 'day') {
    handleBackToMonth()
  } else if (currentViewLevel.value === 'month') {
    handleBackToYear()
  }
}

const handleBackToYear = () => {
  currentViewLevel.value = 'year'
  selectedYear.value = null
  selectedMonth.value = null
  selectedDay.value = null
  reposStore.dimensionRepos = []
}

const handleBackToMonth = () => {
  currentViewLevel.value = 'month'
  selectedDay.value = null
  // 重新加载当前月份数据
  loadPeriodData({
    year: selectedYear.value,
    month: selectedMonth.value
  })
}

// 加载时间段数据
const loadPeriodData = async (periodParams, page = 1) => {
  try {
    if (page === 1) {
      reposStore.dimensionLoading = true
    } else {
      isLoadingMore.value = true
    }

    const result = await reposStore.fetchTimelinePeriod(periodParams, page, 12)

    hasMore.value = result.hasMore
    currentPageInPeriod.value = page
  } catch (error) {
    message.error('加载时间段数据失败: ' + error.message)
  } finally {
    reposStore.dimensionLoading = false
    isLoadingMore.value = false
  }
}

// 滚动加载更多
const handleScroll = async () => {
  if (!reposContainerRef.value || isLoadingMore.value || !hasMore.value) return

  const container = reposContainerRef.value
  const scrollTop = container.scrollTop
  const scrollHeight = container.scrollHeight
  const clientHeight = container.clientHeight

  // 距离底部100px时触发加载
  if (scrollTop + clientHeight >= scrollHeight - 100) {
    const period = {
      year: selectedYear.value,
      month: selectedMonth.value,
      day: selectedDay.value
    }

    currentPageInPeriod.value += 1
    await loadPeriodData(period, currentPageInPeriod.value)
  }
}

// 初始化
const initializeTimeline = async () => {
  await reposStore.fetchTimelineDimensions()

  // 默认加载最近一年数据
  if (timelineData.value?.years?.length > 0) {
    const latestYear = timelineData.value.years[0]
    await handleYearClick(latestYear)
  }
}

// 生命周期
onMounted(async () => {
  await initializeTimeline()

  // 监听滚动事件
  nextTick(() => {
    if (reposContainerRef.value) {
      reposContainerRef.value.addEventListener('scroll', handleScroll)
    }
  })
})

onUnmounted(() => {
  if (reposContainerRef.value) {
    reposContainerRef.value.removeEventListener('scroll', handleScroll)
  }
})
</script>

<style scoped>
.timeline-view {
  width: 100%;
  height: 100%;
}

.timeline-layout {
  display: flex;
  gap: 24px;
  height: calc(100vh - 200px);
}

/* 左侧时间轴 */
.timeline-sidebar {
  width: 280px;
  flex-shrink: 0;
  background: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.timeline-header {
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.timeline-header h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.timeline-container {
  flex: 1;
  overflow-y: auto;
  padding: 24px 16px;
  position: relative;
}

/* 垂直线 */
.timeline-line {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2px;
  background: #e0e0e0;
  transform: translateX(-50%);
}

/* 时间轴项目 */
.timeline-items {
  position: relative;
}

.timeline-item {
  position: relative;
  padding-left: 0;
  padding-right: 0;
  margin-bottom: 20px;
  cursor: pointer;
  min-height: 60px;
}

/* 时间轴圆点 - 完美居中在垂直线上 */
.timeline-dot {
  position: absolute;
  left: calc(50% - 8px);
  top: 22px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: white;
  border: 3px solid #3b82f6;
  box-shadow: 0 2px 8px rgba(59, 130, 246, 0.2);
  transition: all 0.3s ease;
  z-index: 2;
}

.timeline-dot--parent {
  left: calc(50% - 9px);
  top: 21px;
  width: 18px;
  height: 18px;
  border-width: 4px;
  border-color: #6366f1;
  box-shadow: 0 2px 12px rgba(99, 102, 241, 0.25);
}

.timeline-item:hover .timeline-dot {
  transform: scale(1.2);
  border-color: #2563eb;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
}

.timeline-item--active .timeline-dot {
  background: #3b82f6;
  border-color: #3b82f6;
  transform: scale(1.3);
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.4);
}

.timeline-item--parent .timeline-dot {
  background: white;
}

/* 时间轴内容 */
.timeline-content {
  position: absolute;
  left: calc(50% + 30px);
  right: 10px;
  top: 10px;
  padding: 12px 16px;
  background: #fafafa;
  border-radius: 8px;
  transition: all 0.3s ease;
  border-left: 3px solid transparent;
}

.timeline-item:hover .timeline-content {
  background: #f0f9ff;
  border-left-color: #3b82f6;
  box-shadow: 0 2px 8px rgba(59, 130, 246, 0.1);
  transform: translateX(4px);
}

.timeline-item--active .timeline-content {
  background: #eff6ff;
  border-left-color: #3b82f6;
  box-shadow: 0 2px 12px rgba(59, 130, 246, 0.15);
  transform: translateX(6px);
}

.timeline-item--parent .timeline-content {
  background: #f5f5f5;
  border-left-color: #6366f1;
}

.timeline-title {
  font-size: 15px;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 6px;
}

.timeline-item--active .timeline-title {
  color: #1e40af;
}

.timeline-desc {
  font-size: 13px;
  color: #6b7280;
}

.timeline-item--active .timeline-desc {
  color: #3b82f6;
}

/* 右侧内容区 */
.timeline-content-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.repos-container {
  flex: 1;
  overflow-y: auto;
  padding: 4px;
}

.repos-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
  padding: 4px;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 24px;
  color: #999;
}

/* 滚动条样式 */
.timeline-container::-webkit-scrollbar,
.repos-container::-webkit-scrollbar {
  width: 6px;
}

.timeline-container::-webkit-scrollbar-thumb,
.repos-container::-webkit-scrollbar-thumb {
  background: #e0e0e0;
  border-radius: 3px;
}

.timeline-container::-webkit-scrollbar-thumb:hover,
.repos-container::-webkit-scrollbar-thumb:hover {
  background: #c0c0c0;
}

/* 响应式设计 */
@media (max-width: 768px) {
  .timeline-layout {
    flex-direction: column;
    height: auto;
  }

  .timeline-sidebar {
    width: 100%;
    max-height: 300px;
  }

  .repos-grid {
    grid-template-columns: 1fr;
  }
}
</style>
